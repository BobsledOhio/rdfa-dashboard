<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="ContentApp">

  <!-- ══ IDENTITY ══════════════════════════════════════════════════════════ -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Roger D. Fields Associates, Inc.</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <!-- ══ DISPLAY ═══════════════════════════════════════════════════════════ -->
  <DisplayName DefaultValue="RDFA Dashboard"/>
  <Description DefaultValue="Live RDFA project gallery, team roster, services, and discussion prompts — embedded directly in your slide."/>
  <IconUrl DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/rdfa-dashboard/icon.png"/>
  <HighResolutionIconUrl DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/rdfa-dashboard/icon.png"/>
  <SupportUrl DefaultValue="https://www.rdfa.com"/>

  <!-- ══ HOSTS ══════════════════════════════════════════════════════════════ -->
  <Hosts>
    <Host Name="Presentation"/>
  </Hosts>

  <!-- ══ REQUIREMENTS ══════════════════════════════════════════════════════ -->
  <Requirements>
    <Sets>
      <Set Name="Selection" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <!-- ══ SOURCE + SIZE ══════════════════════════════════════════════════════
       ★ Replace YOUR_GITHUB_USERNAME and rdfa-dashboard with your values ★  -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/rdfa-dashboard/script-lab-widget.html"/>
    <RequestedWidth>800</RequestedWidth>
    <RequestedHeight>600</RequestedHeight>
  </DefaultSettings>

  <!-- ══ PERMISSIONS ═══════════════════════════════════════════════════════ -->
  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
